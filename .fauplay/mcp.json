{
  "servers": {
    "reveal-cli": {
      "type": "stdio",
      "command": "node",
      "args": ["tools/mcp/reveal-cli/server.mjs"]
    },
    "timm-classifier": {
      "type": "stdio",
      "command": "python3",
      "callTimeoutMs": 120000,
      "args": [
        "tools/mcp/timm-classifier/server.py",
        "--config",
        "tools/mcp/timm-classifier/config.json"
      ]
    },
    "batch-rename": {
      "type": "stdio",
      "command": "node",
      "args": [
        "tools/mcp/batch-rename/server.mjs"
      ]
    },
    "soft-delete": {
      "type": "stdio",
      "command": "node",
      "args": [
        "tools/mcp/soft-delete/server.mjs"
      ]
    },
    "video-same-duration": {
      "type": "stdio",
      "command": "node",
      "callTimeoutMs": 20000,
      "args": [
        "tools/mcp/video-same-duration/server.mjs"
      ]
    }
  }
}
